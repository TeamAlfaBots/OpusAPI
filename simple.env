# ---- Server ----
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ---- Security ----
# Optional master key. If set, /download requires header: X-API-Key: <value>
API_KEY=alfaAPI_xyzabcd_111
# Download token lifetime in seconds
TOKEN_TTL=300
# Invalidate token after first successful use (true/false)
ONE_TIME_TOKENS=true
# Entropy bytes for tokens
TOKEN_BYTES=32

# ---- yt-dlp / streaming ----
# Max video height for type=video
VIDEO_MAX_HEIGHT=720
# Seconds to cache resolved direct media URLs
URL_CACHE_TTL=1800
# Max concurrent yt-dlp extractions
MAX_EXTRACTIONS=4
# Optional: path to a cookies.txt for age-restricted content
COOKIES_FILE=
# Optional: proxy for yt-dlp, e.g. socks5://127.0.0.1:9050
YTDLP_PROXY=

